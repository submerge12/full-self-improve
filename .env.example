# LLM_PROVIDER may be "deepseek", "qwen", or unset for mock mode.
LLM_PROVIDER=

# Leave API keys empty in local mock mode. Never commit real secrets.
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# Default local SQLite database URL.
DATABASE_URL=file:./knowledge-loop.db

# Runtime API database path used by Next route adapters.
KNOWLEDGE_LOOP_DB_PATH=./knowledge-loop.db

# Optional bearer token required by protected runtime API routes.
KNOWLEDGE_LOOP_API_TOKEN=

# Markdown vault runtime adapter config. Set the root locally, for example to a Holly dataset checkout.
KNOWLEDGE_LOOP_VAULT_ROOT=
KNOWLEDGE_LOOP_ADAPTER_ID=holly-vault
KNOWLEDGE_LOOP_VAULT_INCLUDE=**/*.md
KNOWLEDGE_LOOP_VAULT_EXCLUDE=90_待确认/**,private/**,draft/**,**/drafts/**,**/draft-*
